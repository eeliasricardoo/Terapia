# Exemplo: .env.local
# Copie este arquivo para .env.local e preencha com suas credenciais

# ============================================
# Supabase (obrigatório)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ============================================
# Banco de Dados - Prisma (obrigatório)
# ============================================
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJETO].supabase.co:5432/postgres

# ============================================
# Segurança (obrigatório em produção)
# ============================================
# Chave de criptografia AES-256 para dados sensíveis de saúde (LGPD).
# DEVE ter exatamente 32 caracteres. Gere uma com: openssl rand -base64 32 | cut -c1-32
ENCRYPTION_KEY=sua-chave-de-32-caracteres-aqui!

# ============================================
# Stripe - Pagamentos (obrigatório)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# Daily.co - Videochamadas (obrigatório)
# ============================================
DAILY_API_KEY=sua-daily-api-key-aqui

# ============================================
# Upstash Redis - Rate Limiting (opcional, recomendado)
# ============================================
# Sem estas variáveis, o rate limiting será desabilitado (não recomendado em produção)
UPSTASH_REDIS_REST_URL=https://seu-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu-token-aqui

# ============================================
# App (obrigatório)
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Ambiente
# ============================================
AMBIENT=DEVELOPER

# ============================================
# Resend - Email (obrigatório para emails reais)
# ============================================
RESEND_API_KEY=sua-chave-api-resend-aqui
