generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                    @id @default(uuid())
  name                String?
  email               String                    @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                UserRole                  @default(PATIENT)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  patientAppointments Appointment[]             @relation("PatientAppointments")
  companyProfile      CompanyProfile?
  participants        ConversationParticipant[]
  diaryEntries        DiaryEntry[]
  sentMessages        Message[]                 @relation("SentMessages")
  notifications       Notification[]
  profiles            Profile?
  psychologistProfile PsychologistProfile?

  @@map("users")
}

model Appointment {
  id                    String              @id @default(uuid())
  patientId             String              @map("patient_id")
  psychologistId        String              @map("psychologist_id")
  scheduledAt           DateTime            @map("scheduled_at")
  durationMinutes       Int                 @default(50) @map("duration_minutes")
  status                AppointmentStatus   @default(SCHEDULED)
  price                 Decimal             @db.Decimal(10, 2)
  meetingUrl            String?             @map("meeting_url")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  paymentMethod         String?             @map("payment_method")
  sessionType           String              @default("Terapia Individual") @map("session_type")
  healthInsurancePlanId String?             @map("health_insurance_plan_id")
  healthInsurancePolicy String?             @map("health_insurance_policy")
  stripeSessionId       String?             @unique @map("stripe_session_id")
  reminderSentAt        DateTime?           @map("reminder_sent_at")
  stripePaymentIntentId String?             @unique @map("stripe_payment_intent_id")
  healthInsurance       HealthInsurance?    @relation(fields: [healthInsurancePlanId], references: [id])
  patient               User                @relation("PatientAppointments", fields: [patientId], references: [id])
  psychologist          PsychologistProfile @relation(fields: [psychologistId], references: [id])

  @@index([patientId])
  @@index([psychologistId])
  @@index([scheduledAt])
  @@map("appointments")
}

model Profile {
  id                    String                    @id @default(uuid())
  fullName              String?                   @map("full_name")
  avatarUrl             String?                   @map("avatar_url")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  birth_date            DateTime?                 @db.Date
  document              String?                   @unique
  phone                 String?
  gender                String?
  profession            String?
  addressLine           String?                   @map("address_line")
  city                  String?
  state                 String?
  zipCode               String?                   @map("zip_code")
  role                  UserRole                  @default(PATIENT)
  user_id               String                    @unique
  onboardingData        Json?                     @map("onboarding_data")
  healthInsuranceId     String?                   @map("health_insurance_id")
  healthInsurancePolicy String?                   @map("health_insurance_policy")
  anamnesis             Anamnesis?
  companyMembers        CompanyMember[]
  evolutions            Evolution[]
  psychologistLinks     PatientPsychologistLink[] @relation("PatientLinks")
  patientLinks          PatientPsychologistLink[] @relation("PsychologistLinks")
  healthInsurance       HealthInsurance?          @relation("PatientInsurance", fields: [healthInsuranceId], references: [id])
  users                 User                      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model PsychologistProfile {
  id                       String                  @id @default(uuid())
  userId                   String                  @unique
  crp                      String?                 @unique
  bio                      String?
  specialties              String[]                @default([])
  pricePerSession          Decimal?                @map("price_per_session") @db.Decimal(10, 2)
  videoPresentationUrl     String?                 @map("video_presentation_url")
  isVerified               Boolean                 @default(false) @map("is_verified")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")
  weeklySchedule           Json?                   @map("weekly_schedule")
  timezone                 String                  @default("America/Sao_Paulo")
  academicLevel            String?
  accountNumber            String?
  accountType              String?
  bank                     String?
  crpExpiration            DateTime?
  taxIdNumber              String?
  taxIdType                String?
  title                    String?
  university               String?
  yearsOfExperience        Int?
  sessionDuration          Int                     @default(50) @map("session_duration")
  suspensionReason         String?                 @map("suspension_reason")
  diplomaUrl               String?                 @map("diploma_url")
  licenseUrl               String?                 @map("license_url")
  externalSchedulingUrl    String?                 @map("external_scheduling_url")
  stripeAccountId          String?                 @unique @map("stripe_account_id")
  monthlyPlanDiscount      Int                     @default(20) @map("monthly_plan_discount")
  monthlyPlanEnabled       Boolean                 @default(false) @map("monthly_plan_enabled")
  monthlyPlanSessions      Int                     @default(4) @map("monthly_plan_sessions")
  stripeOnboardingComplete Boolean                 @default(false) @map("stripe_onboarding_complete")
  appointments             Appointment[]
  coupons                  Coupon[]
  plans                    Plan[]
  acceptedInsurances       PsychologistInsurance[]
  user                     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleOverrides        ScheduleOverride[]

  @@map("psychologist_profiles")
}

model Coupon {
  id             String              @id @default(uuid())
  psychologistId String              @map("psychologist_id")
  code           String
  type           String
  value          Decimal             @db.Decimal(10, 2)
  maxUses        Int?                @map("max_uses")
  used           Int                 @default(0)
  active         Boolean             @default(true)
  expiresAt      DateTime?           @map("expires_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  psychologist   PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([psychologistId, code])
  @@map("coupons")
}

model Plan {
  id             String              @id @default(uuid())
  psychologistId String              @map("psychologist_id")
  name           String
  sessions       Int
  price          Decimal             @db.Decimal(10, 2)
  discount       Int                 @default(0)
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  psychologist   PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@map("plans")
}

model ScheduleOverride {
  id             String              @id @default(uuid())
  psychologistId String              @map("psychologist_id")
  date           String
  type           String
  slots          Json
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  psychologist   PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([psychologistId, date])
  @@map("schedule_overrides")
}

model PatientPsychologistLink {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  psychologistId String   @map("psychologist_id")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  patient        Profile  @relation("PatientLinks", fields: [patientId], references: [id], onDelete: Cascade)
  psychologist   Profile  @relation("PsychologistLinks", fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([patientId, psychologistId])
  @@map("patient_psychologist_links")
}

model Anamnesis {
  id                   String   @id @default(uuid())
  patientId            String   @unique @map("patient_id")
  psychologistId       String   @map("psychologist_id")
  mainComplaint        String?  @map("main_complaint")
  familyHistory        String?  @map("family_history")
  medication           String?
  diagnosticHypothesis String?  @map("diagnostic_hypothesis")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  patient              Profile  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("anamnesis")
}

model Evolution {
  id             String   @id @default(uuid())
  patientId      String   @map("patient_id")
  psychologistId String   @map("psychologist_id")
  mood           String?
  publicSummary  String?  @map("public_summary")
  privateNotes   String?  @map("private_notes")
  date           DateTime @default(now())
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  patient        Profile  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("evolutions")
}

model DiaryEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  mood      Int
  emotions  String[] @default([])
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("diary_entries")
}

model Conversation {
  id            String                    @id @default(uuid())
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")
  lastMessageAt DateTime?                 @map("last_message_at")
  participants  ConversationParticipant[]
  messages      Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  lastReadAt     DateTime?    @map("last_read_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

model CompanyProfile {
  id               String          @id @default(uuid())
  userId           String          @unique @map("user_id")
  name             String
  cnpj             String?         @unique
  logoUrl          String?         @map("logo_url")
  organizationCode String          @unique @map("organization_code")
  active           Boolean         @default(true)
  benefitConfig    Json?           @map("benefit_config")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  members          CompanyMember[]
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model CompanyMember {
  id        String         @id @default(uuid())
  companyId String         @map("company_id")
  profileId String         @map("profile_id")
  status    String         @default("ACTIVE")
  joinedAt  DateTime       @default(now()) @map("joined_at")
  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([companyId, profileId])
  @@map("company_members")
}

model HealthInsurance {
  id            String                  @id @default(uuid())
  name          String                  @unique
  logoUrl       String?                 @map("logo_url")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  appointments  Appointment[]
  profiles      Profile[]               @relation("PatientInsurance")
  psychologists PsychologistInsurance[]

  @@map("health_insurances")
}

model PsychologistInsurance {
  id                  String              @id @default(uuid())
  psychologistId      String              @map("psychologist_id")
  healthInsuranceId   String              @map("health_insurance_id")
  healthInsurance     HealthInsurance     @relation(fields: [healthInsuranceId], references: [id], onDelete: Cascade)
  psychologistProfile PsychologistProfile @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([psychologistId, healthInsuranceId])
  @@map("psychologist_insurances")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
  PENDING_PAYMENT
}

enum UserRole {
  PATIENT
  PSYCHOLOGIST
  COMPANY
  ADMIN
}
